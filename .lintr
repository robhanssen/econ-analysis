linters: linters_with_defaults(
    indentation_linter(indent = 4L),
    line_length_linter(120),
    object_name_linter = object_name_linter(styles = c("snake_case", "symbols", "SNAKE_CASE"), regexes = character()),
    pipe_consistency_linter = pipe_consistency_linter(pipe = "auto"),
    object_usage_linter = NULL,
    commented_code_linter = NULL)

